set hlsearch
set relativenumber
set number relativenumber
set incsearch
set ignorecase
set smartcase
set noshowmatch
set hidden
set noerrorbells
set linebreak

set tabstop=4 softtabstop=4
set shiftwidth=4
set expandtab

set noswapfile
set nobackup
set undodir=~/.vim/undodir
set undofile

set so=4

filetype off
syntax on

set encoding=utf-8
set listchars=trail:·

set mouse = ""
let mapleader = ' '

set updatetime=500

filetype plugin indent on
